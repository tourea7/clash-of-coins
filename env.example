# ============================================================
# CLASH OF COINS — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le .env sur GitHub!
# ============================================================

PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Supabase (créer un compte gratuit sur supabase.com)
SUPABASE_URL=https://TON_PROJET.supabase.co
SUPABASE_ANON_KEY=TON_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TON_SERVICE_ROLE_KEY

# Orange Money CI (https://developer.orange.com)
ORANGE_MERCHANT_KEY=
ORANGE_ACCESS_TOKEN=

# Wave CI (https://wave.com/en/business)
WAVE_SECRET_KEY=

# MTN MoMo (https://momodeveloper.mtn.com)
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_ENV=sandbox

# Moov Money
MOOV_API_KEY=

# Sécurité
JWT_SECRET=changez_moi_avec_une_chaine_aleatoire_tres_longue
